<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <DutyDef>
    <defName>FFF_DefendRoom</defName>
    <alwaysShowWeapon>true</alwaysShowWeapon>
    <thinkNode Class="ThinkNode_Priority">
      <subNodes>

        <li Class="JobGiver_AIDefendPoint">
          <targetAcquireRadius>15</targetAcquireRadius>
          <targetKeepRadius>72</targetKeepRadius>
        </li>
        <li Class="JobGiver_FightFiresNearPoint">
          <maxDistFromPoint>25</maxDistFromPoint>
        </li>
        <li Class="ThinkNode_ForbidOutsideFlagRadius">
          <maxDistToSquadFlag>16</maxDistToSquadFlag>
          <subNodes>
            <li Class="ThinkNode_Subtree">
              <treeDef>SatisfyBasicNeedsAndWork</treeDef>
            </li>
          </subNodes>
        </li>
        <li Class="Fortified.JobGiver_WanderInDutyRoom">
          <wanderRadius>20</wanderRadius>
        </li>
      </subNodes>
    </thinkNode>
  </DutyDef>

  <DutyDef>
    <defName>FFF_ScoutAdvance</defName>
    <alwaysShowWeapon>true</alwaysShowWeapon>
    <thinkNode Class="ThinkNode_Priority">
      <subNodes>
        <!-- 受击或近距威胁时还击 -->
        <li Class="Fortified.JobGiver_FFFScoutFight">
          <minRangedReach>12</minRangedReach>
          <reachMultiplier>1</reachMultiplier>
          <retaliateWindowTicks>600</retaliateWindowTicks>
        </li>
        <!-- 主行为深入玩家建筑群 -->
        <li Class="Fortified.JobGiver_FFFScoutAdvance">
          <jobMaxDuration>1500</jobMaxDuration>
          <visitedRange>6</visitedRange>
          <sampleLimit>24</sampleLimit>
        </li>
        <!-- 忘了 -->
        <li Class="JobGiver_WanderAnywhere">
          <maxDanger>Deadly</maxDanger>
        </li>
      </subNodes>
    </thinkNode>
  </DutyDef>

</Defs>