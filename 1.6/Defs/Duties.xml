            <li Class="ThinkNode_Subtree">
              <treeDef>SatisfyBasicNeedsAndWork</treeDef>
            </li>
          </subNodes>
        </li>
        <li Class="Fortified.JobGiver_WanderInDutyRoom">
          <wanderRadius>20</wanderRadius>
        </li>
      </subNodes>
    </thinkNode>
  </DutyDef>

</Defs>